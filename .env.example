# DashScope API key — 在首次启动时也可以通过浏览器的 /settings 页面填写。
DASHSCOPE_API_KEY=

# 可选：切换到国际版（新加坡）Endpoint，用于使用 qwen3.6-plus 等国际版独占模型。
# 国内版不需要设置（默认）。国际版必须同时使用新加坡地域的 API Key。
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# 聊天模型名称。不填则使用 config/rag.yml 里的默认值 (qwen3-max)。
# 可选：qwen3-max / qwen-plus / qwen-turbo / qwen3.6-plus（仅国际版）
# CHAT_MODEL_NAME=qwen3-max
