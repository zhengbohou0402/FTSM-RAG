# DashScope is used by ChatTongyi, DashScopeEmbeddings, and Qwen-VL image extraction.
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Optional: switch to international (Singapore) endpoint for models like qwen3.6-plus.
# 国内版不需要设置（默认）。国际版必须同时使用新加坡地域的 API Key。
# 获取国际版 API Key：https://modelstudio.console.alibabacloud.com/?tab=playground#/api-key
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# Admin API key required for upload, delete, and training endpoints.
ADMIN_API_KEY=change-me-to-a-long-random-secret

# MySQL connection settings (required — run init_db.sql first to create the database)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=ftsm_rag

# Optional LangSmith tracing settings.
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=ftsm-rag
