# DashScope is used by ChatTongyi, DashScopeEmbeddings, and Qwen-VL image extraction.
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Admin API key required for upload, delete, and training endpoints.
ADMIN_API_KEY=change-me-to-a-long-random-secret

# Optional LangSmith tracing settings.
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=ftsm-rag
